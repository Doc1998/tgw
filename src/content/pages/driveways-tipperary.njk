---
title: 'Driveways Tipperary | Tipperary Groundworks'
description: 'Expert driveways in Tipperary. Resin, tarmac, block paving & more. Fast free quotes, fully insured, serving Clonmel, Nenagh, Thurles & all of Co. Tipperary.'
preloadImg: '/assets/images/driveways-hero.jpg'
permalink: '/driveways-tipperary/'
eleventyNavigation:
  key: Driveways
  order: 600
---

{% extends "layouts/base.html" %}

{% block head %}
{% endblock %}

{% block body %}
<style>
  :root {
    --pd-primary: #292524;
    --pd-accent: #B45309;
    --pd-light: #F5F0E8;
    --pd-white: #ffffff;
    --pd-font-display: 'Barlow Condensed', sans-serif;
    --pd-font-body: 'Barlow', sans-serif;
  }

  .tipperary-groundworks-driveways *,
  .tipperary-groundworks-driveways *::before,
  .tipperary-groundworks-driveways *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .tipperary-groundworks-driveways {
    font-family: var(--pd-font-body);
    color: var(--pd-primary);
    background: var(--pd-white);
    overflow-x: hidden;
  }

  /* ── BUTTONS ── */
  .tipperary-groundworks-driveways .btn {
    display: inline-block;
    font-family: var(--pd-font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 1.75rem;
    border-radius: 4px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .tipperary-groundworks-driveways .btn:focus-visible {
    outline: 3px solid var(--pd-accent);
    outline-offset: 3px;
  }
  .tipperary-groundworks-driveways .btn-accent {
    background: var(--pd-accent);
    color: var(--pd-white);
    border-color: var(--pd-accent);
  }
  .tipperary-groundworks-driveways .btn-accent:hover {
    background: #92400E;
    border-color: #92400E;
    transform: translateY(-2px);
  }
  .tipperary-groundworks-driveways .btn-outline {
    background: transparent;
    color: var(--pd-white);
    border-color: var(--pd-white);
  }
  .tipperary-groundworks-driveways .btn-outline:hover {
    background: var(--pd-white);
    color: var(--pd-primary);
    transform: translateY(-2px);
  }
  .tipperary-groundworks-driveways .btn-outline-dark {
    background: transparent;
    color: var(--pd-primary);
    border-color: var(--pd-primary);
  }
  .tipperary-groundworks-driveways .btn-outline-dark:hover {
    background: var(--pd-primary);
    color: var(--pd-white);
    transform: translateY(-2px);
  }

  /* ── EYEBROW ── */
  .tipperary-groundworks-driveways .eyebrow {
    display: inline-block;
    font-family: var(--pd-font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--pd-accent);
    border-left: 3px solid var(--pd-accent);
    padding-left: 0.6rem;
    margin-bottom: 0.75rem;
  }

  /* ── SECTION TITLES ── */
  .tipperary-groundworks-driveways .section-title {
    font-family: var(--pd-font-display);
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 1rem;
  }
  .tipperary-groundworks-driveways .section-title.light {
    color: var(--pd-white);
  }

  .tipperary-groundworks-driveways .section-body {
    font-size: 1rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 65ch;
  }
  .tipperary-groundworks-driveways .section-body.light {
    color: #e7e5e4;
  }

  /* ══════════════════════════════
     1. HERO
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: flex-end;
    background: url('/assets/images/driveways-hero.jpg') center center / cover no-repeat;
  }
  .tipperary-groundworks-driveways .driveways-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20,15,10,0.88) 0%, rgba(20,15,10,0.45) 55%, rgba(20,15,10,0.15) 100%);
    z-index: 1;
  }
  .tipperary-groundworks-driveways .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.25rem 4rem;
  }
  .tipperary-groundworks-driveways .hero-inner h1 {
    font-family: var(--pd-font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--pd-white);
    max-width: 18ch;
    margin-bottom: 1rem;
  }
  .tipperary-groundworks-driveways .hero-inner h1 span {
    color: var(--pd-accent);
  }
  .tipperary-groundworks-driveways .hero-sub {
    font-size: 1.15rem;
    color: #e7e5e4;
    max-width: 52ch;
    line-height: 1.55;
    margin-bottom: 2rem;
  }
  .tipperary-groundworks-driveways .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 2.5rem;
  }
  .tipperary-groundworks-driveways .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .tipperary-groundworks-driveways .trust-pill {
    font-family: var(--pd-font-display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pd-white);
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 2px;
    padding: 0.35rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .tipperary-groundworks-driveways .trust-pill svg {
    flex-shrink: 0;
  }

  /* ── diagonal clip ── */
  .tipperary-groundworks-driveways .clip-bottom {
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 48px), 0 100%);
  }

  /* ══════════════════════════════
     2. INTRO
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-intro {
    background: var(--pd-light);
    padding: 5rem 1.25rem 6rem;
  }
  .tipperary-groundworks-driveways .intro-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  .tipperary-groundworks-driveways .intro-text {}
  .tipperary-groundworks-driveways .intro-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #44403c;
    margin-bottom: 1.25rem;
    max-width: 62ch;
  }
  .tipperary-groundworks-driveways .intro-img {
    position: relative;
  }
  .tipperary-groundworks-driveways .intro-img img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  }
  .tipperary-groundworks-driveways .intro-img::before {
    content: '';
    position: absolute;
    top: -10px;
    left: -10px;
    right: 10px;
    bottom: 10px;
    border: 2px solid var(--pd-accent);
    border-radius: 4px;
    pointer-events: none;
    z-index: 0;
  }
  .tipperary-groundworks-driveways .intro-img img {
    position: relative;
    z-index: 1;
  }
  .tipperary-groundworks-driveways .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .tipperary-groundworks-driveways .badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.1rem;
    background: var(--pd-white);
    border-radius: 4px;
    border-top: 3px solid var(--pd-accent);
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }
  .tipperary-groundworks-driveways .badge-label {
    font-family: var(--pd-font-display);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pd-primary);
  }
  .tipperary-groundworks-driveways .badge-sub {
    font-size: 0.78rem;
    color: #78716c;
  }
  .tipperary-groundworks-driveways .stars {
    color: #FBBF24;
    font-size: 1rem;
    letter-spacing: 0.05em;
  }

  /* ══════════════════════════════
     3. ALTERNATING SERVICE BLOCKS
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .services-blocks {
    background: var(--pd-white);
    padding: 5rem 1.25rem;
  }
  .tipperary-groundworks-driveways .services-blocks-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .tipperary-groundworks-driveways .services-blocks-inner > .eyebrow,
  .tipperary-groundworks-driveways .services-blocks-inner > .section-title {
    text-align: center;
    display: block;
    border-left: none;
    padding-left: 0;
    margin-bottom: 0.5rem;
  }
  .tipperary-groundworks-driveways .services-blocks-inner > .section-title {
    margin-bottom: 3.5rem;
  }

  .tipperary-groundworks-driveways .service-block {
    display: grid;
    gap: 2.5rem;
    align-items: center;
    margin-bottom: 5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid #e7e5e4;
  }
  .tipperary-groundworks-driveways .service-block:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }
  .tipperary-groundworks-driveways .service-block-img img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  }
  .tipperary-groundworks-driveways .service-block-text h3 {
    font-family: var(--pd-font-display);
    font-size: 1.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--pd-primary);
    margin-bottom: 1rem;
    line-height: 1.1;
  }
  .tipperary-groundworks-driveways .service-block-text h3::before {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--pd-accent);
    margin-bottom: 0.75rem;
  }
  .tipperary-groundworks-driveways .service-block-text p {
    font-size: 1rem;
    line-height: 1.75;
    color: #44403c;
    margin-bottom: 1rem;
  }
  .tipperary-groundworks-driveways .service-block-text .link-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--pd-font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pd-accent);
    text-decoration: none;
    border-bottom: 2px solid var(--pd-accent);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .tipperary-groundworks-driveways .service-block-text .link-more:hover {
    color: #92400E;
    border-color: #92400E;
  }

  /* ══════════════════════════════
     4. PROCESS
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-process {
    background: var(--pd-primary);
    padding: 5rem 1.25rem 6rem;
    clip-path: polygon(0 48px, 100% 0, 100% calc(100% - 48px), 0 100%);
    margin: -2px 0;
  }
  .tipperary-groundworks-driveways .process-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .tipperary-groundworks-driveways .process-inner .eyebrow {
    color: var(--pd-accent);
    border-color: var(--pd-accent);
    display: inline-block;
    margin-bottom: 0.75rem;
  }
  .tipperary-groundworks-driveways .process-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .tipperary-groundworks-driveways .process-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-top: 3px solid var(--pd-accent);
    border-radius: 4px;
    padding: 2rem 1.5rem;
    text-align: left;
  }
  .tipperary-groundworks-driveways .process-num {
    font-family: var(--pd-font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--pd-accent);
    line-height: 1;
    margin-bottom: 0.5rem;
    opacity: 0.9;
  }
  .tipperary-groundworks-driveways .process-card h3 {
    font-family: var(--pd-font-display);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--pd-white);
    margin-bottom: 0.75rem;
  }
  .tipperary-groundworks-driveways .process-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #a8a29e;
  }

  /* ══════════════════════════════
     5. WHY CHOOSE US
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-why {
    background: var(--pd-light);
    padding: 5rem 1.25rem;
  }
  .tipperary-groundworks-driveways .why-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .tipperary-groundworks-driveways .why-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .tipperary-groundworks-driveways .why-card {
    background: var(--pd-white);
    border-radius: 4px;
    border-top: 4px solid var(--pd-accent);
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    padding: 2rem 1.5rem;
    text-align: left;
  }
  .tipperary-groundworks-driveways .why-card-icon {
    width: 44px;
    height: 44px;
    background: var(--pd-accent);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .tipperary-groundworks-driveways .why-card-icon svg {
    color: var(--pd-white);
  }
  .tipperary-groundworks-driveways .why-card h3 {
    font-family: var(--pd-font-display);
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--pd-primary);
    margin-bottom: 0.5rem;
  }
  .tipperary-groundworks-driveways .why-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #57534e;
  }

  /* ══════════════════════════════
     PRICING SECTION
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-pricing {
    background: var(--pd-white);
    padding: 5rem 1.25rem;
    border-top: 2px solid #e7e5e4;
  }
  .tipperary-groundworks-driveways .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .tipperary-groundworks-driveways .pricing-intro {
    max-width: 62ch;
    margin-bottom: 2.5rem;
  }
  .tipperary-groundworks-driveways .pricing-intro p {
    font-size: 1rem;
    line-height: 1.75;
    color: #44403c;
    margin-bottom: 1rem;
  }
  .tipperary-groundworks-driveways .pricing-grid {
    display: grid;
    gap: 1.25rem;
  }
  .tipperary-groundworks-driveways .price-card {
    border-left: 4px solid var(--pd-accent);
    background: var(--pd-light);
    border-radius: 0 4px 4px 0;
    padding: 1.5rem;
  }
  .tipperary-groundworks-driveways .price-card h3 {
    font-family: var(--pd-font-display);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--pd-primary);
    margin-bottom: 0.4rem;
  }
  .tipperary-groundworks-driveways .price-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: #57534e;
  }
  .tipperary-groundworks-driveways .pricing-note {
    margin-top: 2rem;
    font-size: 0.9rem;
    color: #78716c;
    line-height: 1.6;
    max-width: 62ch;
  }

  /* ══════════════════════════════
     6. FAQ
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-faq {
    background: var(--pd-light);
    padding: 5rem 1.25rem;
    border-top: 2px solid #e7e5e4;
  }
  .tipperary-groundworks-driveways .faq-inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }
  .tipperary-groundworks-driveways .faq-inner .section-title {
    margin-bottom: 0.5rem;
  }
  .tipperary-groundworks-driveways .faq-intro {
    font-size: 1rem;
    color: #57534e;
    margin-bottom: 3rem;
    line-height: 1.65;
  }
  .tipperary-groundworks-driveways .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-align: left;
    border-top: 2px solid #d6d3d1;
  }
  .tipperary-groundworks-driveways .faq-item {
    border-bottom: 1px solid #d6d3d1;
  }
  .tipperary-groundworks-driveways .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 1.25rem 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    cursor: pointer;
    font-family: var(--pd-font-display);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--pd-primary);
    text-align: left;
    line-height: 1.3;
  }
  .tipperary-groundworks-driveways .faq-question:focus-visible {
    outline: 3px solid var(--pd-accent);
    outline-offset: 2px;
  }
  .tipperary-groundworks-driveways .faq-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    background: var(--pd-accent);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    margin-top: 2px;
  }
  .tipperary-groundworks-driveways .faq-icon svg {
    transition: transform 0.25s ease;
    color: var(--pd-white);
  }
  .tipperary-groundworks-driveways .faq-item.open .faq-icon svg {
    transform: rotate(45deg);
  }
  .tipperary-groundworks-driveways .faq-answer {
    display: none;
    padding: 0 0 1.5rem;
  }
  .tipperary-groundworks-driveways .faq-item.open .faq-answer {
    display: block;
  }
  .tipperary-groundworks-driveways .faq-answer p {
    font-size: 0.98rem;
    line-height: 1.75;
    color: #44403c;
  }

  /* ══════════════════════════════
     7. TESTIMONIALS
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-testimonials {
    background: var(--pd-primary);
    padding: 5rem 1.25rem;
    clip-path: polygon(0 48px, 100% 0, 100% calc(100% - 48px), 0 100%);
    margin: -1px 0;
  }
  .tipperary-groundworks-driveways .testimonials-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .tipperary-groundworks-driveways .testimonials-inner .eyebrow {
    color: var(--pd-accent);
    border-color: var(--pd-accent);
    display: inline-block;
  }
  .tipperary-groundworks-driveways .testimonials-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .tipperary-groundworks-driveways .testi-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-top: 3px solid var(--pd-accent);
    border-radius: 4px;
    padding: 2rem 1.5rem;
    text-align: left;
  }
  .tipperary-groundworks-driveways .testi-card .stars {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }
  .tipperary-groundworks-driveways .testi-text {
    font-size: 1rem;
    line-height: 1.75;
    color: #e7e5e4;
    margin-bottom: 1.25rem;
    font-style: italic;
  }
  .tipperary-groundworks-driveways .testi-author {
    font-family: var(--pd-font-display);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pd-accent);
  }

  /* ══════════════════════════════
     8. AREAS SERVED
  ══════════════════════════════ */
  .tipperary-groundworks-driveways .driveways-areas {
    background: var(--pd-white);
    padding: 5rem 1.25rem;
  }
  .tipperary-groundworks-driveways .areas-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .tipperary-groundworks-driveways .areas-inner .eyebrow {
    display: block;
    margin-bottom: 0.5rem;
  }
  .tipperary-groundworks-driveways .areas-text {
    max-width: 62ch;
    font-size: 1rem;
    line-height: 1.75;
    color: #44403c;
    margin: 1.5rem 0 2.5rem;
  }
  .tipperary-groundworks-driveways .area-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .tipperary-groundworks-driveways .area-chip {
    font-family: var(--pd-font-display);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--pd-primary);
    border: 2px solid var(--pd-primary);
    border-radius: 2px;
    padding: 0.4rem 0.85rem;
    transition: background 0.15s, color 0.15s;
  }
  .tipperary-groundworks-driveways .area-chip:hover {
    background: var(--pd-primary);
