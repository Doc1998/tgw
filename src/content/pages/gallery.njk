---
title: 'Gallery | Tipperary Groundworks — Driveway, Patio & Groundworks Photos'
description: 'Browse photos of completed driveway, patio, groundworks and pipe laying projects across County Tipperary by Tipperary Groundworks.'
permalink: '/gallery/'
eleventyNavigation:
  key: Gallery
---

{% extends "layouts/base.html" %}

{% block head %}
{% endblock %}

{% block body %}
<style>
  :root {
    --pd-primary: #292524;
    --pd-accent: #B45309;
    --pd-light: #F5F0E8;
    --pd-white: #ffffff;
    --pd-font-display: 'Barlow Condensed', sans-serif;
    --pd-font-body: 'Barlow', sans-serif;
    --pd-section-pad: clamp(2.75rem, 7vw, 5rem);
  }

  .pd-gallery-page *,
  .pd-gallery-page *::before,
  .pd-gallery-page *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .pd-gallery-page {
    font-family: var(--pd-font-body);
    color: var(--pd-primary);
    background: var(--pd-white);
    overflow-x: hidden;
  }

  .pd-gallery-page img { max-width: 100%; height: auto; display: block; }

  .pd-gallery-page a:focus-visible,
  .pd-gallery-page button:focus-visible {
    outline: 2px solid var(--pd-accent);
    outline-offset: 3px;
  }

  .pd-gallery-page .container {
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .pd-gallery-page .eyebrow {
    display: inline-block;
    font-family: var(--pd-font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pd-accent);
    border-left: 3px solid var(--pd-accent);
    padding-left: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .pd-gallery-page .section-title {
    font-family: var(--pd-font-display);
    font-size: clamp(1.65rem, 5.5vw, 2.6rem);
    font-weight: 700;
    line-height: 1.08;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    overflow-wrap: break-word;
  }

  .pd-gallery-page .divider-rule {
    width: 48px;
    height: 3px;
    background: var(--pd-accent);
    margin: 0.9rem 0 0;
    border: none;
  }

  .pd-gallery-page .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 44px;
    font-family: var(--pd-font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 1.75rem;
    border-radius: 4px;
    border: 2px solid var(--pd-accent);
    background: transparent;
    color: var(--pd-accent);
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease;
  }

  .pd-gallery-page .btn:hover {
    background: var(--pd-accent);
    color: var(--pd-white);
  }

  .pd-gallery-page .btn--accent {
    background: var(--pd-accent);
    color: var(--pd-white);
  }

  .pd-gallery-page .btn--accent:hover {
    background: #92400E;
    border-color: #92400E;
  }

  /* ─── PAGE BANNER ─────────────────────────────────────────── */
  .pd-gal-banner {
    background: var(--pd-primary);
    padding: clamp(3rem, 9vw, 5.5rem) 0 clamp(2.5rem, 7vw, 4rem);
    text-align: center;
  }

  .pd-gal-banner .eyebrow {
    border-left: none;
    padding-left: 0;
    display: block;
  }

  .pd-gal-banner .section-title {
    color: var(--pd-white);
  }

  .pd-gal-banner p.pd-gal-banner__sub {
    max-width: 640px;
    margin: 1rem auto 0;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
  }

  /* ─── GALLERY SECTIONS ────────────────────────────────────── */
  .pd-gal-section {
    padding: var(--pd-section-pad) 0;
  }

  .pd-gal-section:nth-of-type(even) {
    background: var(--pd-light);
  }

  .pd-gal-section__header {
    max-width: 680px;
    margin: 0 auto clamp(1.75rem, 5vw, 2.5rem);
    text-align: center;
  }

  .pd-gal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.5rem;
  }

  .pd-gal-item {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: none;
    padding: 0;
    background: var(--pd-white);
    cursor: pointer;
  }

  .pd-gal-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .pd-gal-item:hover img,
  .pd-gal-item:focus-visible img {
    transform: scale(1.08);
  }

  .pd-gal-loadmore {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: clamp(1.75rem, 5vw, 2.5rem);
  }

  .pd-gal-loadmore__count {
    font-size: 0.9rem;
    color: #6B6460;
  }

  /* ─── LIGHTBOX ────────────────────────────────────────────── */
  .pd-lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(20, 17, 15, 0.94);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3.5rem 1rem;
  }

  .pd-lightbox[hidden] { display: none; }

  .pd-lightbox__img {
    max-width: 100%;
    max-height: 82vh;
    object-fit: contain;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
  }

  .pd-lightbox__close,
  .pd-lightbox__prev,
  .pd-lightbox__next {
    position: absolute;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.25);
    color: var(--pd-white);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.18s ease;
  }

  .pd-lightbox__close:hover,
  .pd-lightbox__prev:hover,
  .pd-lightbox__next:hover {
    background: var(--pd-accent);
    border-color: var(--pd-accent);
  }

  .pd-lightbox__close {
    top: 1rem;
    right: 1rem;
  }

  .pd-lightbox__prev {
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .pd-lightbox__next {
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .pd-lightbox__count {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--pd-font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.75);
  }

  /* ─── FINAL CTA ───────────────────────────────────────────── */
  .pd-gal-cta {
    background: var(--pd-primary);
    padding: var(--pd-section-pad) 0;
    text-align: center;
  }

  .pd-gal-cta .section-title { color: var(--pd-white); }

  .pd-gal-cta p {
    max-width: 560px;
    margin: 1rem auto 1.75rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
  }

  .pd-gal-cta__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  /* ─── RESPONSIVE ──────────────────────────────────────────── */
  @media (max-width: 479px) {
    .pd-gal-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 0.35rem;
    }

    .pd-lightbox { padding: 3rem 0.5rem; }
    .pd-lightbox__prev { left: 0.25rem; }
    .pd-lightbox__next { right: 0.25rem; }
  }

  @media (min-width: 768px) {
    .pd-gal-grid {
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 0.65rem;
    }
  }

  @media (min-width: 1024px) {
    .pd-gal-grid {
      grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
      gap: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pd-gal-item img,
    .pd-gal-loadmore .btn,
    .pd-lightbox__close,
    .pd-lightbox__prev,
    .pd-lightbox__next {
      transition: none;
    }
  }
</style>

<div class="pd-gallery-page">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- BANNER -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="pd-gal-banner" aria-labelledby="gal-banner-heading">
    <div class="container">
      <p class="eyebrow">Our Work</p>
      <h1 class="section-title" id="gal-banner-heading">Project Gallery</h1>
      <p class="pd-gal-banner__sub">A look at driveways, patios, groundworks and pipe laying jobs completed across County Tipperary. Tap any photo to view it full size.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SET 1: moreimgs-1 (112 photos) -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="pd-gal-section" aria-labelledby="gal-set1-heading">
    <div class="container">
      <div class="pd-gal-section__header">
        <p class="eyebrow">Recent Jobs</p>
        <h2 class="section-title" id="gal-set1-heading">Driveways, Patios &amp; Groundworks</h2>
        <hr class="divider-rule" style="margin-left:auto;margin-right:auto;">
      </div>

      <div class="pd-gal-grid" id="gal-grid-1" data-folder="assets/images/moreimgs-1" data-prefix="tgw" data-total="112">
        {% for i in range(1, 25) %}
        <button type="button" class="pd-gal-item" data-index="{{ i }}" aria-label="Open photo {{ i }} of 112 in full size">
          <img src="/assets/images/moreimgs-1/tgw%20({{ i }}).jpeg" alt="Tipperary Groundworks completed project photo {{ i }}" loading="lazy" decoding="async">
        </button>
        {% endfor %}
      </div>

      <div class="pd-gal-loadmore">
        <p class="pd-gal-loadmore__count" id="gal-count-1">Showing 24 of 112 photos</p>
        <button
          type="button"
          class="btn pd-gal-loadmore-btn"
          id="gal-loadmore-1"
          data-target="gal-grid-1"
          data-count="gal-count-1"
          data-batch="24"
          data-remaining="{% for i in range(25, 113) %}{{ i }}{% if not loop.last %},{% endif %}{% endfor %}"
        >Load More Photos</button>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SET 2: moreimgs-2 (81 photos) -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="pd-gal-section" aria-labelledby="gal-set2-heading">
    <div class="container">
      <div class="pd-gal-section__header">
        <p class="eyebrow">More Completed Work</p>
        <h2 class="section-title" id="gal-set2-heading">Further Projects Around The County</h2>
        <hr class="divider-rule" style="margin-left:auto;margin-right:auto;">
      </div>

      <div class="pd-gal-grid" id="gal-grid-2" data-folder="assets/images/moreimgs-2" data-prefix="tgw2" data-total="81">
        {% for i in range(1, 25) %}
        <button type="button" class="pd-gal-item" data-index="{{ i }}" aria-label="Open photo {{ i }} of 81 in full size">
          <img src="/assets/images/moreimgs-2/tgw2%20({{ i }}).jpeg" alt="Tipperary Groundworks completed project photo {{ i }}" loading="lazy" decoding="async">
        </button>
        {% endfor %}
      </div>

      <div class="pd-gal-loadmore">
        <p class="pd-gal-loadmore__count" id="gal-count-2">Showing 24 of 81 photos</p>
        <button
          type="button"
          class="btn pd-gal-loadmore-btn"
          id="gal-loadmore-2"
          data-target="gal-grid-2"
          data-count="gal-count-2"
          data-batch="24"
          data-remaining="{% for i in range(25, 82) %}{{ i }}{% if not loop.last %},{% endif %}{% endfor %}"
        >Load More Photos</button>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CTA -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="pd-gal-cta" aria-labelledby="gal-cta-heading">
    <div class="container">
      <h2 class="section-title" id="gal-cta-heading">Like What You See?</h2>
      <p>Get in touch for a free, no-obligation quote on your driveway, patio or groundworks project anywhere in County Tipperary.</p>
      <div class="pd-gal-cta__ctas">
        <a href="/contact/" class="btn btn--accent">Get a Free Quote</a>
        <a href="tel:+353873566934" class="btn">Call 087 356 6934</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- LIGHTBOX -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div class="pd-lightbox" id="pd-lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <button type="button" class="pd-lightbox__close" id="pd-lightbox-close" aria-label="Close photo viewer">&times;</button>
    <button type="button" class="pd-lightbox__prev" id="pd-lightbox-prev" aria-label="Previous photo">&#8249;</button>
    <img class="pd-lightbox__img" id="pd-lightbox-img" src="" alt="">
    <button type="button" class="pd-lightbox__next" id="pd-lightbox-next" aria-label="Next photo">&#8250;</button>
    <p class="pd-lightbox__count" id="pd-lightbox-count"></p>
  </div>

</div>

<script>
  (function () {
    function imgUrl(folder, prefix, n) {
      return '/' + folder + '/' + prefix + '%20(' + n + ').jpeg';
    }

    /* ── Load more ── */
    document.querySelectorAll('.pd-gal-loadmore-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var grid = document.getElementById(btn.dataset.target);
        var countEl = document.getElementById(btn.dataset.count);
        if (!grid) return;

        var remaining = btn.dataset.remaining
          ? btn.dataset.remaining.split(',').filter(Boolean).map(Number)
          : [];
        var batchSize = parseInt(btn.dataset.batch, 10) || 24;
        var batch = remaining.splice(0, batchSize);

        batch.forEach(function (n) {
          var item = document.createElement('button');
          item.type = 'button';
          item.className = 'pd-gal-item';
          item.dataset.index = String(n);
          item.setAttribute('aria-label', 'Open photo ' + n + ' of ' + grid.dataset.total + ' in full size');

          var img = document.createElement('img');
          img.src = imgUrl(grid.dataset.folder, grid.dataset.prefix, n);
          img.alt = 'Tipperary Groundworks completed project photo ' + n;
          img.loading = 'lazy';
          img.decoding = 'async';

          item.appendChild(img);
          grid.appendChild(item);
        });

        btn.dataset.remaining = remaining.join(',');
        var shown = grid.querySelectorAll('.pd-gal-item').length;
        if (countEl) {
          countEl.textContent = 'Showing ' + shown + ' of ' + grid.dataset.total + ' photos';
        }
        if (remaining.length === 0) {
          btn.hidden = true;
        }
      });
    });

    /* ── Lightbox ── */
    var lightbox = document.getElementById('pd-lightbox');
    var lbImg = document.getElementById('pd-lightbox-img');
    var lbCount = document.getElementById('pd-lightbox-count');
    var lbClose = document.getElementById('pd-lightbox-close');
    var lbPrev = document.getElementById('pd-lightbox-prev');
    var lbNext = document.getElementById('pd-lightbox-next');
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var state = { folder: '', prefix: '', total: 0, index: 1 };
    var lastFocused = null;

    function updateLightboxImg() {
      lbImg.src = imgUrl(state.folder, state.prefix, state.index);
      lbImg.alt = 'Tipperary Groundworks project photo ' + state.index + ' of ' + state.total;
      lbCount.textContent = state.index + ' / ' + state.total;
    }

    function openLightbox(folder, prefix, total, index, triggerEl) {
      state = { folder: folder, prefix: prefix, total: total, index: index };
      lastFocused = triggerEl || document.activeElement;
      updateLightboxImg();
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      lbClose.focus();
    }

    function closeLightbox() {
      lightbox.hidden = true;
      document.body.style.overflow = '';
      if (lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus();
      }
    }

    function showPrev() {
      state.index = state.index > 1 ? state.index - 1 : state.total;
      updateLightboxImg();
    }

    function showNext() {
      state.index = state.index < state.total ? state.index + 1 : 1;
      updateLightboxImg();
    }

    document.querySelectorAll('.pd-gal-grid').forEach(function (grid) {
      grid.addEventListener('click', function (e) {
        var btn = e.target.closest('.pd-gal-item');
        if (!btn) return;
        openLightbox(
          grid.dataset.folder,
          grid.dataset.prefix,
          parseInt(grid.dataset.total, 10),
          parseInt(btn.dataset.index, 10),
          btn
        );
      });
    });

    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', showPrev);
    lbNext.addEventListener('click', showNext);

    lightbox.addEventListener('click', function (e) {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', function (e) {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showPrev();
      if (e.key === 'ArrowRight') showNext();
    });
  })();
</script>

{% endblock %}
